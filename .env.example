# LLM provider: "openrouter" (default) or "ollama"
PROVIDER=openrouter

# Model to use
# OpenRouter examples: google/gemini-2.5-flash-lite, openai/gpt-4o-mini
# Ollama examples: qwen3:0.6b, llama3.2
MODEL=google/gemini-2.5-flash-lite

# Required when PROVIDER=openrouter
OPENROUTER_API_KEY=your-key-here

# Required when PROVIDER=ollama (default shown)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama only: /api/chat `think` (thinking models). Default: low.
# Values: true, false, high, medium, low. Set to "off" to omit the field (for non-thinking models).
# See https://docs.ollama.com/api/chat
# OLLAMA_THINK=low

# OpenRouter base URL (default shown)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter only: `reasoning.effort` on chat completions. Default: minimal. Set to
# "off" to omit the `reasoning` field entirely. Values: xhigh, high, medium, low, minimal, none
# See https://openrouter.ai/docs/api/api-reference/chat/send-chat-completion-request
OPENROUTER_REASONING_EFFORT=minimal

# OpenRouter only: `reasoning.summary` — auto, concise, detailed. Omit for default.
# OPENROUTER_REASONING_SUMMARY=

# Streaming (default: true). Set to "false" to disable token-by-token streaming.
# STREAMING=true

# Dangerous: skip all destructive-operation confirmations. When true, the AI can
# edit, delete, rename, and bulk-operate immediately after a tool call.
# SKIP_CONFIRMATIONS=false

# Context window guard (default: 128000 tokens). Set to 0 to disable.
# CONTEXT_MAX_TOKENS=128000
# CONTEXT_WARN_RATIO=0.80

# How much detail to show for Tool entries in the chat panel.
#   default — `[tool_name] Brief action` (no args, no result). Cleanest for end users.
#   minimal — `[tool_name] Description with args` (e.g. paths, regex).
#   full    — `[tool_name] Description with args → result snippet (capped)`. For technical users.
# TOOL_DISPLAY_VERBOSITY=default

# How to surface model reasoning / thinking tokens (when the model emits them).
# Requires a thinking model + matching provider settings (OPENROUTER_REASONING_EFFORT,
# OLLAMA_THINK). Has no effect on non-thinking models.
#   off    — discard thinking entirely (default).
#   inline — show a dimmed `[Thinking… (N chars)]` indicator while the model reasons; cleared
#            once the answer arrives. Nothing kept in chat history.
#   full   — stream thinking tokens live and keep a permanent dimmed entry in chat after.
# THINKING_DISPLAY=off

# ── Local provider (PROVIDER=local, build with --features local) ──────────────
# HuggingFace repo and filename to download on first run (cached in ~/.cache/huggingface/)
# LOCAL_MODEL_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
# LOCAL_MODEL_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf
# Skip download and use a GGUF file you already have on disk
# LOCAL_MODEL_PATH=/path/to/your/model.gguf
# Context window size in tokens (default: 8192)
# LOCAL_CONTEXT_TOKENS=8192
# Number of layers to offload to GPU (0 = CPU only; requires local-metal or local-cuda feature)
# LOCAL_GPU_LAYERS=0
# Thread count for inference (default: all available cores)
# LOCAL_THREADS=
# Maximum output tokens per response (default: 1024)
# LOCAL_MAX_OUTPUT_TOKENS=1024
# Sampling temperature (0.0 = greedy, default: 0.1)
# LOCAL_TEMPERATURE=0.1
